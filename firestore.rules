// NOTE: Client‑side rate limiting is enforced in the web app, but for stronger protection you should
// add server‑side throttling (e.g., via Cloud Functions) or monitor write patterns in Firebase.

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Validate game ID format (alphanumeric, underscores, hyphens only)
    function isValidGameId(id) {
      return id is string 
        && id.size() >= 3 
        && id.size() <= 100
        && id.matches('^[a-zA-Z0-9_-]+$');
    }
    
    // Validate game data structure and field sizes
    function isValidGame(data) {
      let requiredKeys = ['id', 'userId', 'whiteName', 'blackName', 'moves', 'fens', 'savedAt'];
      let optionalKeys = ['tournament', 'timeControl', 'date', 'result', 'pgn', 'analysis', 'whiteAccuracy', 'blackAccuracy'];
      let allKeys = requiredKeys + optionalKeys;
      
      // Check all keys are valid
      let validKeys = data.keys().hasAll(requiredKeys) 
        && data.keys().toSet().diff(allKeys.toSet()).size() == 0;
      
      // Validate field types and sizes
      let validMoves = data.moves is list && data.moves.size() <= 500;
      let validFens = data.fens is list && data.fens.size() <= 501;
      let validId = isValidGameId(data.id);
      let validUserId = data.userId is string && data.userId.size() <= 128;
      let validWhiteName = data.whiteName is string && data.whiteName.size() <= 100;
      let validBlackName = data.blackName is string && data.blackName.size() <= 100;
      let validSavedAt = data.savedAt is string && data.savedAt.size() <= 50;
      
      // Optional fields validation
      let validTournament = !('tournament' in data) || (data.tournament is string && data.tournament.size() <= 200);
      let validTimeControl = !('timeControl' in data) || (data.timeControl is string && data.timeControl.size() <= 50);
      let validDate = !('date' in data) || (data.date is string && data.date.size() <= 20);
      let validResult = !('result' in data) || (data.result is string && data.result.size() <= 10);
      let validPgn = !('pgn' in data) || (data.pgn is string && data.pgn.size() <= 500000);
      
      return validKeys && validMoves && validFens && validId && validUserId 
        && validWhiteName && validBlackName && validSavedAt
        && validTournament && validTimeControl && validDate && validResult && validPgn;
    }
    
    // Check if user owns the game
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User's private game library
    match /users/{userId}/games/{gameId} {
      // Validate gameId path parameter
      let validPath = isValidGameId(gameId);
      
      allow read: if validPath && isOwner(userId);
      
      allow create: if validPath && isOwner(userId) 
        && isValidGame(request.resource.data)
        && request.resource.data.userId == userId;
      
      allow update, delete: if validPath && isOwner(userId);
    }

    // Shared games — anyone can read, only owner can write
    match /sharedGames/{gameId} {
      let validPath = isValidGameId(gameId);
      
      allow read: if validPath;
      
      allow create: if validPath && request.auth != null 
        && isValidGame(request.resource.data)
        && request.resource.data.userId == request.auth.uid;
      
      allow update, delete: if validPath && request.auth != null 
        && request.auth.uid == resource.data.userId;
    }
  }
}
